# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Database (Supabase connection string)
DATABASE_URL=postgresql://postgres:[YOUR-PASSWORD]@db.your-project.supabase.co:5432/postgres

# Algolia
NEXT_PUBLIC_ALGOLIA_APP_ID=your-app-id
NEXT_PUBLIC_ALGOLIA_SEARCH_KEY=your-search-only-api-key
ALGOLIA_ADMIN_KEY=your-admin-api-key
ALGOLIA_PRODUCTS_INDEX=sv_products

# Amazon PAAPI (Associates)
AMAZON_ACCESS_KEY=your-access-key
AMAZON_SECRET_KEY=your-secret-key
AMAZON_ASSOCIATE_TAG=your-associate-tag
AMAZON_MARKETPLACE=www.amazon.com

# Resend (Email)
RESEND_API_KEY=re_your_key
EMAIL_FROM=hello@shoppingvegan.com

# Skimlinks (publisher ID from Skimlinks dashboard)
NEXT_PUBLIC_SKIMLINKS_PUBLISHER_ID=your-publisher-id

# App
NEXT_PUBLIC_APP_URL=http://localhost:3000
